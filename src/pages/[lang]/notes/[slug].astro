---
import { getTranslations, type Lang } from '../../../i18n';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import EmptyState from '../../../components/EmptyState.astro';
import posts from '../../../data/posts';

interface Params {
  lang: Lang;
  slug: string;
}

export function getStaticPaths() {
  return posts
    .filter((p) => p.published)
    .flatMap((post) => [
      { params: { lang: 'en' as Lang, slug: post.slug } },
      { params: { lang: 'zh' as Lang, slug: post.slug } },
    ]);
}

const { lang, slug } = Astro.params as Params;
const t = getTranslations(lang);
const base = `/${lang}`;
const post = posts.find((p) => p.slug === slug);

if (!post) {
  return Astro.redirect(`${base}/notes`);
}

const title = lang === 'zh' ? post.title.zh : post.title.en;
const summary = lang === 'zh' ? post.summary.zh : post.summary.en;
---

<BaseLayout lang={lang} title={title} description={summary} narrow>
  <article class="py-8">
    <!-- Back link -->
    <a href={`${base}/notes`} class="text-link mb-6 inline-flex items-center gap-1 text-sm">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
      {t.blog.backToList}
    </a>

    <!-- Header -->
    <header class="mb-8">
      <h1 class="text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl dark:text-slate-50">
        {title}
      </h1>
      <div class="mt-4 flex flex-wrap items-center gap-3">
        <time datetime={post.date} class="text-sm text-slate-400">{post.date}</time>
        <div class="flex flex-wrap gap-1.5">
          {post.tags.map((tag) => <span class="tag-accent">{tag}</span>)}
        </div>
      </div>
    </header>

    <!-- Summary callout -->
    <div class="card-accent mb-10 rounded-lg border-l-accent-500 p-5">
      <p class="text-sm font-medium text-slate-700 dark:text-slate-300">
        {summary}
      </p>
    </div>

    <!-- Article body placeholder -->
    <div class="prose-article mt-8">
      <EmptyState
        text={lang === 'zh' ? '完整文章内容待添加。请将 Markdown 文件放入 src/content/posts/ 目录。' : 'Full article content coming soon. Place Markdown files in src/content/posts/.'}
      >
        <p class="mt-2 text-xs text-slate-400">
          {lang === 'zh' ? '参考 README 中"添加博客"章节了解如何添加文章。' : 'See the "Adding Blog Posts" section in README for instructions.'}
        </p>
      </EmptyState>
    </div>
  </article>
</BaseLayout>
