---
/**
 * Individual blog post / note page.
 *
 * TODO: For real Markdown/MDX support, create content collections in
 * src/content/posts/ and use Astro's getCollection() API. The current
 * implementation uses the data/posts.ts placeholder data for the top
 * section and displays a TODO content area below.
 */
import { getTranslations, type Lang } from '../../../i18n';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import posts from '../../../data/posts';

interface Params {
  lang: Lang;
  slug: string;
}

export function getStaticPaths() {
  return posts
    .filter((p) => p.published)
    .flatMap((post) => [
      { params: { lang: 'en' as Lang, slug: post.slug } },
      { params: { lang: 'zh' as Lang, slug: post.slug } },
    ]);
}

const { lang, slug } = Astro.params as Params;
const t = getTranslations(lang);
const base = `/${lang}`;

const post = posts.find((p) => p.slug === slug);

if (!post) {
  return Astro.redirect(`${base}/notes`);
}

const title = lang === 'zh' ? post.title.zh : post.title.en;
const summary = lang === 'zh' ? post.summary.zh : post.summary.en;
---

<BaseLayout lang={lang} title={title} description={summary} narrow>
  <article class="py-8">
    <!-- Back link -->
    <a href={`${base}/notes`} class="text-link mb-6 inline-block text-sm">
      {t.blog.backToList}
    </a>

    <header class="mb-8">
      <h1
        class="text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl dark:text-slate-50"
      >
        {title}
      </h1>
      <div class="mt-3 flex flex-wrap items-center gap-3">
        <time datetime={post.date} class="text-sm text-slate-400">
          {post.date}
        </time>
        <div class="flex flex-wrap gap-1.5">
          {post.tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      </div>
    </header>

    <!-- Summary -->
    <div
      class="rounded-xl border-l-4 border-accent-500 bg-accent-50 p-4 text-sm leading-relaxed text-accent-900 dark:border-accent-400 dark:bg-accent-950 dark:text-accent-200"
    >
      {summary}
    </div>

    <!-- TODO: Full article content -->
    <div class="prose-article mt-8">
      <div
        class="rounded-xl border border-dashed border-slate-300 p-8 text-center dark:border-slate-700"
      >
        <p class="text-slate-500 dark:text-slate-400">
          {lang === 'zh'
            ? '📝 完整文章内容待添加。请将 Markdown 文件放入 src/content/posts/ 目录。'
            : '📝 Full article content coming soon. Place Markdown files in src/content/posts/.'}
        </p>
        <p class="mt-2 text-xs text-slate-400">
          {lang === 'zh'
            ? '参考 README 中"添加博客"章节了解如何添加文章。'
            : 'See the "Adding Blog Posts" section in README for instructions.'}
        </p>
      </div>
    </div>
  </article>
</BaseLayout>
