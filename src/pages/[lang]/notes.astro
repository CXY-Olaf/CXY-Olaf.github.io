---
export { getStaticPaths } from './_staticPaths';
import { getTranslations, type Lang } from '../../i18n';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import posts from '../../data/posts';

const { lang } = Astro.params as { lang: Lang };
const t = getTranslations(lang);
const visiblePosts = posts.filter((p) => p.published).sort((a, b) => b.date.localeCompare(a.date));
---

<BaseLayout lang={lang} title={t.meta.notesTitle} description={t.meta.notesDescription}>
  <section class="section">
    <h1 class="section-title">{t.blog.heading}</h1>

    {
      visiblePosts.length === 0 ? (
        <div class="empty-state">
          <span class="empty-state-icon">📖</span>
          <p class="empty-state-text">{t.blog.empty}</p>
        </div>
      ) : (
        <div class="mx-auto max-w-3xl space-y-5">
          {visiblePosts.map((post) => (
            <BlogCard lang={lang} post={post} t={t} />
          ))}
        </div>
      )
    }
  </section>
</BaseLayout>
