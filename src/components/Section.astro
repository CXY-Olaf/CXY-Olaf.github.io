---
export interface Props {
  id?: string;
  title?: string;
  subtitle?: string;
  class?: string;
  /** Use alternating background tint */
  alt?: boolean;
}

const { id, title, subtitle, class: extraClass = '', alt = false } = Astro.props;
---

<section
  {id}
  class:list={[
    'section',
    alt ? 'section-alt' : '',
    extraClass,
  ]}
>
  {
    title && (
      <div class="mb-12">
        <h2 class="section-title">{title}</h2>
        {subtitle && <p class="section-subtitle">{subtitle}</p>}
      </div>
    )
  }
  <slot />
</section>
