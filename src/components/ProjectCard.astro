---
import type { Project } from '../data/projects';
import type { Translations } from '../i18n/en';
import type { Lang } from '../i18n';

interface Props {
  lang: Lang;
  project: Project;
  t: Translations;
}

const { lang, project, t } = Astro.props;
const title = lang === 'zh' ? project.title.zh : project.title.en;
const desc = lang === 'zh' ? project.description.zh : project.description.en;

const statusCfg: Record<string, { label: string; class: string }> = {
  'in-progress': { label: t.projects.status.inProgress, class: 'badge-progress' },
  todo: { label: t.projects.status.todo, class: 'badge-todo' },
  notes: { label: t.projects.status.notes, class: 'badge-notes' },
};

const { label: statusLabel, class: statusClass } = statusCfg[project.status] ?? statusCfg.todo;
---

<div class="card group flex flex-col gap-3 hover:-translate-y-1">
  <!-- Header -->
  <div class="flex items-start justify-between gap-3">
    <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-50">
      {title}
    </h3>
    <span class={statusClass}>{statusLabel}</span>
  </div>

  <!-- Description -->
  <p class="text-sm leading-relaxed text-slate-600 dark:text-slate-400">
    {desc}
  </p>

  <!-- Tags -->
  <div class="flex flex-wrap gap-1.5">
    {project.tags.map((tag) => <span class="tag">{tag}</span>)}
  </div>

  <!-- Links -->
  <div class="mt-auto flex gap-4 pt-2 text-sm">
    {project.github && project.github !== 'TODO' ? (
      <a href={project.github} class="text-link" target="_blank" rel="noopener">
        💻 {t.projects.github}
      </a>
    ) : (
      <span class="text-sm text-slate-400 dark:text-slate-600">💻 {t.projects.github}</span>
    )}
    {project.demo && project.demo !== 'TODO' ? (
      <a href={project.demo} class="text-link" target="_blank" rel="noopener">
        🌐 {t.projects.demo}
      </a>
    ) : (
      <span class="text-sm text-slate-400 dark:text-slate-600">🌐 {t.projects.demo}</span>
    )}
  </div>
</div>
