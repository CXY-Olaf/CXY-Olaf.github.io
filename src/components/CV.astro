---
import { getTranslations, type Lang } from '../i18n';
import EmptyState from './EmptyState.astro';

interface Props { lang: Lang; }

const { lang } = Astro.props;
const t = getTranslations(lang);
const base = `/${lang}`;

const headingCls = 'mb-5 flex items-center gap-2 text-xl font-bold text-slate-900 dark:text-slate-50';
---

<div class="mx-auto max-w-3xl space-y-14">
  <!-- Download CV -->
  <div class="text-center">
    <a href="/cv.pdf" class="btn-primary" download>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      {t.cv.download}
    </a>
    <p class="mt-2 text-xs text-slate-400">{t.cv.downloadTip}</p>
  </div>

  <!-- Education -->
  <section>
    <h3 class={headingCls}><span aria-hidden="true">📚</span> {t.cv.education}</h3>
    <div class="space-y-3">
      {t.cv.educationItems.map((item) => (
        <div class="card">
          <h4 class="font-semibold text-slate-900 dark:text-slate-50">{item.degree}</h4>
          <p class="text-sm text-slate-600 dark:text-slate-400">{item.school}</p>
          <p class="text-xs text-slate-400">{item.period}</p>
          {item.notes && <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">{item.notes}</p>}
        </div>
      ))}
    </div>
  </section>

  <!-- Research interests -->
  <section>
    <h3 class={headingCls}><span aria-hidden="true">🔬</span> {t.cv.researchInterests}</h3>
    <div class="card">
      <div class="flex flex-wrap gap-2">
        {t.research.directions.map((d) => <span class="tag-accent">{d.title}</span>)}
      </div>
    </div>
  </section>

  <!-- Publications -->
  <section>
    <h3 class={headingCls}><span aria-hidden="true">📄</span> {t.cv.publications}</h3>
    <EmptyState text={t.publications.empty}>
      <a href={`${base}/publications`} class="text-link mt-3 text-sm">{t.nav.publications} →</a>
    </EmptyState>
  </section>

  <!-- Projects -->
  <section>
    <h3 class={headingCls}><span aria-hidden="true">🛠️</span> {t.cv.projects}</h3>
    <EmptyState icon="🔧" text="TODO">
      <a href={`${base}/projects`} class="text-link mt-3 text-sm">{t.nav.projects} →</a>
    </EmptyState>
  </section>

  <!-- Skills -->
  <section>
    <h3 class={headingCls}><span aria-hidden="true">⚙️</span> {t.cv.skills}</h3>
    <div class="card">
      <p class="text-xs text-slate-400 dark:text-slate-500">
        TODO: Python, PyTorch, Diffusers, CUDA, Linux, Git, LaTeX …
      </p>
    </div>
  </section>

  <!-- Experience -->
  <section>
    <h3 class={headingCls}><span aria-hidden="true">💼</span> {t.cv.experience}</h3>
    <EmptyState icon="🏢" text={t.cv.todo} />
  </section>

  <!-- Awards -->
  <section>
    <h3 class={headingCls}><span aria-hidden="true">🏆</span> {t.cv.awards}</h3>
    <EmptyState icon="🥇" text={t.cv.todo} />
  </section>

  <!-- Contact -->
  <section>
    <h3 class={headingCls}><span aria-hidden="true">📬</span> {t.cv.contact}</h3>
    <div class="card">
      <p class="text-sm text-slate-500 dark:text-slate-400">Email: TODO</p>
      <a href={`${base}/#contact`} class="text-link mt-2 inline-block text-sm">{t.nav.contact} →</a>
    </div>
  </section>
</div>
