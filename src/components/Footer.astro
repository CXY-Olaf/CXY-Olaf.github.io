---
import { getTranslations, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
---

<footer
  class="border-t border-slate-200 bg-white py-8 dark:border-slate-800 dark:bg-slate-950"
>
  <div
    class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 px-4 text-center text-sm text-slate-500 sm:flex-row sm:text-left"
  >
    <div>
      <p>{t.footer.copyright}</p>
      <p class="mt-1">{t.footer.builtWith}</p>
    </div>
    <div class="text-right">
      <p>{t.footer.lastUpdated}: 2026-06</p>
      <p class="mt-1">
        <a
          href={`https://github.com/CXY-Olaf`}
          class="text-accent-600 transition-colors hover:text-accent-800 dark:text-accent-400 dark:hover:text-accent-300"
        >
          GitHub
        </a>
      </p>
    </div>
  </div>
</footer>
