---
import { getTranslations, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
---

<footer class="border-t border-slate-200/60 bg-white py-10 dark:border-slate-800/60 dark:bg-slate-950">
  <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-6 px-5 text-center text-sm sm:flex-row sm:text-left sm:px-8">
    <div class="space-y-1">
      <p class="font-medium text-slate-700 dark:text-slate-300">
        {t.footer.copyright}
      </p>
      <p class="text-slate-400 dark:text-slate-500">
        {t.footer.builtWith}
      </p>
    </div>

    <div class="flex items-center gap-6 text-slate-400 dark:text-slate-500">
      <p>
        {t.footer.lastUpdated}: 2026-06
      </p>
      <a
        href="https://github.com/CXY-Olaf"
        class="text-link text-xs"
        target="_blank"
        rel="noopener"
      >
        GitHub →
      </a>
    </div>
  </div>
</footer>
