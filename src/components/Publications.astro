---
import { getTranslations, type Lang } from '../i18n';
import publications from '../data/publications';
import PublicationItem from './PublicationItem.astro';
import EmptyState from './EmptyState.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
---

{
  publications.length === 0 ? (
    <EmptyState text={t.publications.empty} />
  ) : (
    <div class="mx-auto max-w-3xl space-y-4">
      {publications.slice(0, 3).map((pub, i) => (
        <PublicationItem lang={lang} pub={pub} t={t} index={i} />
      ))}
    </div>
  )
}
