---
// ThemeToggle: cycles light → dark → system on click.
// The inline theme script in BaseLayout already applies the stored/detected
// class before paint; this component only updates state after interaction.
---

<button
  id="theme-toggle"
  class="rounded-md p-1.5 text-slate-600 transition-colors hover:bg-slate-100 dark:text-slate-400 dark:hover:bg-slate-800"
  aria-label="Toggle dark mode"
  title="Toggle theme"
>
  <!-- Sun icon (shown in dark mode → click to go light) -->
  <svg
    id="theme-icon-sun"
    class="hidden dark:block"
    xmlns="http://www.w3.org/2000/svg"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4" />
    <path d="M12 2v2" /><path d="M12 20v2" />
    <path d="m4.93 4.93 1.41 1.41" />
    <path d="m17.66 17.66 1.41 1.41" />
    <path d="M2 12h2" /><path d="M20 12h2" />
    <path d="m6.34 17.66-1.41 1.41" />
    <path d="m19.07 4.93-1.41 1.41" />
  </svg>
  <!-- Moon icon (shown in light mode → click to go dark) -->
  <svg
    id="theme-icon-moon"
    class="block dark:hidden"
    xmlns="http://www.w3.org/2000/svg"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z" />
  </svg>
</button>

<script>
  type ThemeVal = 'light' | 'dark' | 'system';

  function getStored(): ThemeVal {
    return (localStorage.getItem('theme') as ThemeVal) ?? 'system';
  }
  function setStored(t: ThemeVal) {
    localStorage.setItem('theme', t);
  }

  function resolveIsDark(t: ThemeVal): boolean {
    return (
      t === 'dark' ||
      (t === 'system' &&
        window.matchMedia('(prefers-color-scheme: dark)').matches)
    );
  }

  function apply(t: ThemeVal) {
    document.documentElement.classList.toggle('dark', resolveIsDark(t));
  }

  function nextTheme(current: ThemeVal): ThemeVal {
    // cycle: light → dark → system → light
    const order: ThemeVal[] = ['light', 'dark', 'system'];
    const idx = order.indexOf(current);
    return order[(idx + 1) % order.length];
  }

  const btn = document.getElementById('theme-toggle');
  if (btn) {
    btn.addEventListener('click', () => {
      const current = getStored();
      const next = nextTheme(current);
      setStored(next);
      apply(next);
    });
  }

  // Listen for system preference changes when in system mode
  window
    .matchMedia('(prefers-color-scheme: dark)')
    .addEventListener('change', () => {
      if (getStored() === 'system') {
        apply('system');
      }
    });
</script>
