---

<button
  id="theme-toggle"
  class="rounded-lg p-2 text-slate-600 transition-colors hover:bg-slate-100 dark:text-slate-400 dark:hover:bg-slate-800"
  aria-label="Toggle theme"
  title="Toggle theme"
>
  <!-- Sun (dark mode → click for light) -->
  <svg id="theme-sun" class="hidden dark:block" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/>
  </svg>
  <!-- Moon (light mode → click for dark) -->
  <svg id="theme-moon" class="block dark:hidden" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
  </svg>
</button>

<script>
  type T = 'light' | 'dark' | 'system';
  const get = (): T => (localStorage.getItem('theme') as T) ?? 'system';
  const set = (t: T) => localStorage.setItem('theme', t);
  const isDark = (t: T) => t === 'dark' || (t === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches);
  const apply = (t: T) => document.documentElement.classList.toggle('dark', isDark(t));
  const next = (t: T): T => (({ light: 'dark', dark: 'system', system: 'light' }) as Record<T, T>)[t];

  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const n = next(get());
    set(n);
    apply(n);
  });

  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
    if (get() === 'system') apply('system');
  });
</script>
