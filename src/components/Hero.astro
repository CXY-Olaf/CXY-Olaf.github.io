---
import { getTranslations, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
const base = `/${lang}`;

// Research direction tags
const tags = [
  'Diffusion Models',
  'Image Editing',
  'Flow Matching',
  'Optimal Transport',
  'Efficient Inference',
  'AI Infra',
];
---

<section
  class="flex min-h-[calc(100vh-4rem)] items-center px-4 py-16 sm:px-6 lg:px-8"
>
  <div class="mx-auto w-full max-w-4xl text-center">
    <!-- Avatar / initials placeholder -->
    <div class="mx-auto mb-8 flex h-28 w-28 items-center justify-center rounded-full bg-accent-100 text-4xl font-bold text-accent-600 ring-4 ring-accent-50 dark:bg-accent-950 dark:text-accent-400 dark:ring-accent-900">
      {t.hero.initials}
    </div>

    <p class="mb-2 text-lg text-slate-500 dark:text-slate-400">
      {t.hero.greeting}
    </p>

    <h1
      class="text-balance text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl dark:text-slate-50"
    >
      {t.hero.name}
    </h1>

    <p
      class="mt-4 text-lg font-medium text-accent-600 dark:text-accent-400 sm:text-xl"
    >
      {t.hero.subtitle}
    </p>

    <p
      class="mx-auto mt-6 max-w-2xl text-balance text-slate-600 leading-relaxed dark:text-slate-400"
    >
      {t.hero.bio}
    </p>

    <!-- CTA buttons -->
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <a href={`${base}/cv`} class="btn-primary">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
          <polyline points="14 2 14 8 20 8" />
          <line x1="16" y1="13" x2="8" y2="13" />
          <line x1="16" y1="17" x2="8" y2="17" />
          <polyline points="10 9 9 9 8 9" />
        </svg>
        {t.hero.cvButton}
      </a>
      <a href={`${base}/projects`} class="btn-secondary">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect width="18" height="18" x="3" y="3" rx="2" />
          <path d="M9 3v18" />
        </svg>
        {t.hero.projectsButton}
      </a>
      <a href={`${base}/#contact`} class="btn-secondary">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect width="20" height="16" x="2" y="4" rx="2" />
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
        </svg>
        {t.hero.contactButton}
      </a>
    </div>

    <!-- Research tags -->
    <div class="mt-10 flex flex-wrap items-center justify-center gap-2">
      {tags.map((tag) => <span class="tag">{tag}</span>)}
    </div>
  </div>
</section>
