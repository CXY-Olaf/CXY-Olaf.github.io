---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { getTranslations, type Lang } from '../i18n';

export interface Props {
  lang: Lang;
  title?: string;
  description?: string;
  ogImage?: string;
  narrow?: boolean;
  /** Apply hero background glow to the main area */
  heroBg?: boolean;
}

const { lang, title, description, ogImage, narrow = false, heroBg = false } = Astro.props;
const t = getTranslations(lang);
const pageTitle = title ? `${title} — ${t.site.title}` : t.site.title;
const pageDesc = description ?? t.site.description;
const ogUrl = new URL(Astro.url.pathname, Astro.site).href;
const ogImg = ogImage ? new URL(ogImage, Astro.site).href : undefined;
---

<!doctype html>
<html lang={lang === 'zh' ? 'zh-CN' : 'en'} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={t.site.title} />
    {ogImg && <meta property="og:image" content={ogImg} />}

    <link rel="canonical" href={ogUrl} />
    {
      ['en', 'zh'].map((alt) => {
        if (alt === lang) return null;
        const altPath = Astro.url.pathname.replace(`/${lang}`, `/${alt}`);
        return <link rel="alternate" hreflang={alt === 'zh' ? 'zh-CN' : 'en'} href={new URL(altPath, Astro.site).href} />;
      })
    }

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Inline theme script — blocks FOUC -->
    <script is:inline>
      (function() {
        var t = localStorage.getItem('theme') || 'system';
        var d = t === 'dark' || (t === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches);
        document.documentElement.classList.toggle('dark', d);
      })();
    </script>

    <!-- Inter font — loaded async via print-swap trick, never blocks rendering -->
    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
    <noscript><link rel="stylesheet" href="https://rsms.me/inter/inter.css" /></noscript>
  </head>

  <body class="min-h-screen flex flex-col">
    <Navbar lang={lang} />

    <main
      class:list={[
        'flex-1',
        heroBg ? 'bg-hero-glow bg-grid-light dark:bg-grid-dark' : '',
        narrow
          ? 'mx-auto w-full max-w-3xl px-5 py-8 sm:px-8'
          : '',
      ]}
    >
      <slot />
    </main>

    <Footer lang={lang} />
  </body>
</html>
